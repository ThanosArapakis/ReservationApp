{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    // Host "sqlserver" is the compose service name, reachable on the docker network.
    //"DefaultConnection": "Server=sqlserver,1433;Initial Catalog=ReservationDB;User ID=sa;Password=Local_Dev_Pass123!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=True;Connection Timeout=30;"
    "DefaultConnection": "Server=tcp:reservationappserver.database.windows.net,1433;Initial Catalog=ReservationDB;Persist Security Info=False;User ID=adminuser;Password=Adminpass!;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "RabbitMq": {
    // API runs on the host (IDE), broker is the docker container -> reach it via localhost.
    "Host": "localhost",
    "Port": 5672,
    "VirtualHost": "/",
    "UserName": "reservation",
    "Password": "reservation_local",
    "Queue": "ReservationQueue"
  },
  "Smtp": {
    "Host": "mailpit",
    "Port": 1025,
    "EnableSsl": false,
    "UserName": "",
    "Password": "",
    "FromAddress": "noreply@reservationapp.local"
  }
}
